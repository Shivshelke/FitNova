# FitNova Backend Environment Variables
NODE_ENV=development
PORT=3000

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/fitnova

# JWT Secret (change this to a strong random string in production)
JWT_SECRET=fitnova_super_secret_jwt_key_2024
JWT_EXPIRES_IN=30d

# Google OAuth (optional - needed for Google Sign-In)
GOOGLE_CLIENT_ID=your_google_client_id_here
